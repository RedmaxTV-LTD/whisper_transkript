# --- Запуск из корня репозитория (docker-compose.yml с профилем whisper) ---
WHISPER_HOST_PORT=19900
# Хост-путь относительно корня репозитория (по умолчанию в compose то же самое):
WHISPER_MODELS_HOST_DIR=./whisper/models
# В контейнере путь к одной модели (подкаталог с model.bin):
WHISPER_MODEL_PATH=/models/turbo

# --- Если запускаете только whisper/docker-compose.yml из каталога whisper/ ---
# WHISPER_MODELS_HOST_DIR=./models
# WHISPER_MODEL_PATH=/models/turbo

# Параллельных транскрипций на локальном GPU (WHISPER_BACKEND=local).
WHISPER_MAX_CONCURRENT_JOBS=1
# Параллельных jobs при WHISPER_BACKEND=openai (независимо от local).
OPENAI_MAX_CONCURRENT_JOBS=8
# Бэкенд распознавания: local (faster-whisper GPU) | openai (облачный API).
WHISPER_BACKEND=local
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_TRANSCRIBE_MODEL=whisper-1
# OPENAI_TIMEOUT_SEC=600
# OPENAI_MAX_UPLOAD_MB=24
# OPENAI_MAX_RETRIES=3
# При старте whisper-worker: сбросить список whisper:queue и заново поставить все queued/waiting_gpu из Redis (1/true по умолчанию).
# WHISPER_WORKER_QUEUE_FLUSH_ON_START=1
# Фоновые задачи: API (whisper-stt) + worker (whisper-worker) + Redis
WHISPER_JOB_HEARTBEAT_SEC=15
WHISPER_JOB_STALE_SEC=300
# Ключ whisper:worker:alive в Redis (API смотрит worker_available /health и GET /jobs)
# WHISPER_WORKER_ALIVE_TTL_SEC=90
# WHISPER_WORKER_ALIVE_REFRESH_SEC=25
REDIS_URL=redis://redis:6379/0
# Роль процесса: api (только HTTP) или worker (очередь + GPU). В docker-compose задано по сервисам.
# WHISPER_PROCESS_ROLE=api

# Паузы внутри одной фразы Whisper: разбить на отдельные сегменты, если между словами тишина > N сек
# (word_timestamps; 0 = отключить, как раньше — один блок на сегмент модели).
# WHISPER_INTRA_SEGMENT_SPLIT_GAP_SEC=0.45

# Синхронизация RX/TX по url_mix (корреляция огибающих на первых N сек):
# WHISPER_CHANNEL_SYNC_DOWNSAMPLE_STEP=80
# WHISPER_CHANNEL_SYNC_CORR_MAX_SEC=120
# WHISPER_CHANNEL_SYNC_MAX_LAG_SEC=5
# WHISPER_CHANNEL_SYNC_MIN_CORR=0.04
# Макс. |offset| по каналу (сек), если в запросе sync.max_offset_sec не задан:
# WHISPER_SYNC_MAX_OFFSET_SEC=2
WHISPER_COMPUTE_TYPE=float16
WHISPER_LANGUAGE=ru
WHISPER_MODELS_DIR=/models

# WHISPER_API_TOKEN=

# --- Диаризация pyannote.audio (опционально; только WHISPER_BACKEND=local) ---
# Обязательно на hf.co (тот же аккаунт, что для HF_TOKEN) примите пользовательские условия:
#   https://huggingface.co/pyannote/speaker-diarization-3.1
#   https://huggingface.co/pyannote/segmentation-3.0   ← без этого пайплайн падает при загрузке
# Токен read: https://huggingface.co/settings/tokens
# При WHISPER_DIARIZATION=1 worker дожидается загрузки pyannote до BRPOP очереди (меньше риск зависания CUDA вместе с Whisper).
# WHISPER_DIARIZATION=1
# HF_TOKEN=hf_...
# PYANNOTE_DEVICE=cpu   # рекомендуется рядом с faster-whisper на GPU, чтобы не упираться в VRAM
# PYANNOTE_PIPELINE=pyannote/speaker-diarization-3.1
# WHISPER_DIARIZE_DEFAULT=1   # для запросов без поля diarize в JSON

# Первый раз: загрузить CTranslate2 в том (из корня репозитория):
# docker compose --profile whisper run --rm whisper-stt python3 /app/download_models.py
# Из каталога whisper/:
# docker compose run --rm whisper-stt python3 /app/download_models.py
# WHISPER_MODELS_FORCE=1 — перекачать набор по умолчанию
# WHISPER_HF_TOKEN= или HF_TOKEN=

# --- Словарь правильного написания (после распознавания) ---
# Формат — JSON-объект: ошибочная форма → канон. Замена по границам слов, без учёта регистра.
# В Docker по умолчанию: том spelling_config/ → /config/spelling, файл dictionary.json
# (изменения на хосте подхватываются по mtime без перезапуска контейнера).
# WHISPER_SPELLING_CONFIG_DIR=./spelling_config
# WHISPER_SPELLING_DICT_PATH=/config/spelling/dictionary.json
# Локально без compose: пустой WHISPER_SPELLING_DICT_PATH → app/spelling_dictionary.json в образе.
# WHISPER_SPELLING_FIXES=0

# --- Роли спикеров (диаризация): шаблоны фраз в начале записи ---
# WHISPER_SPEAKER_ROLES_CONFIG_DIR=./speaker_roles_config
# WHISPER_SPEAKER_ROLES_CATALOG_PATH=/config/speaker_roles/catalog.json
# WHISPER_SPEAKER_ROLES_CATALOG=0   # отключить — только схема SPEAKER_00/01/02
